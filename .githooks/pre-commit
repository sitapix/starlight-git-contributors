#!/usr/bin/env bash
# Pre-commit hook for starlight-git-contributors.
#
# Wired via `git config core.hooksPath .githooks`, set automatically by the
# root package.json `prepare` script. Runs everything CI runs except the
# docs build (too slow for a commit hook; CI catches it).
#
# Skip in emergencies with `git commit --no-verify`, but fix the cause
# right after.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

step() {
  printf "\n\033[1;34m→ %s\033[0m\n" "$1"
}

# Catch whitespace errors and conflict markers in staged content before
# spending time on lint/types/tests.
step "whitespace + conflict markers (git diff --check)"
git diff --check --cached

step "lint + format (biome ci)"
pnpm exec biome ci .

step "typecheck (tsc --noEmit, strict)"
pnpm typecheck

step "unit tests (node:test)"
pnpm --filter starlight-git-contributors test

printf "\n\033[1;32m✓ pre-commit passed\033[0m\n"
