{
	"name": "starlight-git-contributors",
	"version": "0.2.1",
	"description": "Starlight plugin that adds per-page contributor lists from local git blame. Host-agnostic (GitHub, GitLab, Codeberg, self-hosted, no remote).",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": "./index.ts",
		"./PageContributors.astro": "./components/PageContributors.astro",
		"./overrides/Footer.astro": "./overrides/Footer.astro",
		"./package.json": "./package.json"
	},
	"files": [
		"index.ts",
		"translations.ts",
		"virtual.d.ts",
		"components",
		"libs/cache.ts",
		"libs/git-blame.ts",
		"libs/plugin-internals.ts",
		"libs/prewarm.ts",
		"libs/vite.ts",
		"overrides",
		"README.md"
	],
	"keywords": [
		"astro",
		"starlight",
		"starlight-plugin",
		"contributors",
		"git",
		"blame"
	],
	"license": "MIT",
	"homepage": "https://github.com/sitapix/starlight-git-contributors#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sitapix/starlight-git-contributors.git",
		"directory": "packages/starlight-git-contributors"
	},
	"bugs": {
		"url": "https://github.com/sitapix/starlight-git-contributors/issues"
	},
	"devDependencies": {
		"@astrojs/starlight": "^0.39.0",
		"astro": "^6.0.0"
	},
	"peerDependencies": {
		"@astrojs/starlight": ">=0.39.0"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"test": "node --test --experimental-strip-types 'libs/*.test.ts' 'index.test.ts' 'types.test.ts'"
	}
}
