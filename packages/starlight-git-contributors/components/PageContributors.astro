---
import { contributorsForFile, type RankOptions } from "../libs/git-blame.ts";

// `top` and `ignore` inherit from RankOptions so renames in the data layer
// propagate to the component without manual duplication.
export interface Props extends RankOptions {
	/**
	 * Absolute path to the source file to blame. Defaults to the current
	 * Starlight page's `Astro.locals.starlightRoute.entry.filePath`. Override
	 * only when rendering the component outside its Starlight route context.
	 */
	filePath?: string;
	/**
	 * Show the leading person icon. Default: `true`. Pass `false` to omit,
	 * or use the `icon` named slot to override (e.g. with a Starlight `<Icon>`
	 * or any custom SVG). The built-in icon switches between a single-person
	 * and multi-people glyph based on contributor count.
	 */
	icon?: boolean;
	/**
	 * Accessible name for the contributor list region. Provide it when the
	 * wrapping element does not already give context. Localize the string
	 * yourself; the component does not translate it.
	 */
	ariaLabel?: string;
}

const {
	filePath: explicit,
	top = 5,
	ignore,
	icon = true,
	ariaLabel,
} = Astro.props;

const { starlightRoute } = Astro.locals;
const filePath = explicit ?? starlightRoute?.entry?.filePath;
const lang = starlightRoute?.lang ?? "en";

const contributors = filePath
	? contributorsForFile(filePath, { top, ignore, cache: true })
	: [];
const single = contributors.length === 1;

const parts =
	contributors.length > 0
		? new Intl.ListFormat(lang, {
				style: "long",
				type: "conjunction",
			}).formatToParts(contributors.map((c) => c.name))
		: [];
---

{contributors.length > 0 && (
  <span class="sgc-root" aria-label={ariaLabel}>
    {icon && (
      <span class="sgc-icon" aria-hidden="true">
        <slot name="icon">
          {single ? (
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 21C20 19.6044 20 18.9067 19.8278 18.3389C19.44 17.0605 18.4395 16.06 17.1611 15.6722C16.5933 15.5 15.8956 15.5 14.5 15.5H9.5C8.10444 15.5 7.40665 15.5 6.83886 15.6722C5.56045 16.06 4.56004 17.0605 4.17224 18.3389C4 18.9067 4 19.6044 4 21M16.5 7.5C16.5 9.98528 14.4853 12 12 12C9.51472 12 7.5 9.98528 7.5 7.5C7.5 5.01472 9.51472 3 12 3C14.4853 3 16.5 5.01472 16.5 7.5Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          ) : (
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M22 21V19C22 17.1362 20.7252 15.5701 19 15.126M15.5 3.29076C16.9659 3.88415 18 5.32131 18 7C18 8.67869 16.9659 10.1159 15.5 10.7092M17 21C17 19.1362 17 18.2044 16.6955 17.4693C16.2895 16.4892 15.5108 15.7105 14.5307 15.3045C13.7956 15 12.8638 15 11 15H8C6.13623 15 5.20435 15 4.46927 15.3045C3.48915 15.7105 2.71046 16.4892 2.30448 17.4693C2 18.2044 2 19.1362 2 21M13.5 7C13.5 9.20914 11.7091 11 9.5 11C7.29086 11 5.5 9.20914 5.5 7C5.5 4.79086 7.29086 3 9.5 3C11.7091 3 13.5 4.79086 13.5 7Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          )}
        </slot>
      </span>
    )}
    {parts.map((part) =>
      part.type === 'element'
        ? <span class="sgc-name">{part.value}</span>
        : <Fragment>{part.value}</Fragment>
    )}
  </span>
)}

<style>
  .sgc-icon {
    display: inline-block;
    width: 1em;
    height: 1em;
    vertical-align: -0.15em;
    margin-inline-end: 0.4em;
  }
  .sgc-icon :global(svg) {
    width: 100%;
    height: 100%;
  }
</style>
